API_URL=http://localhost:3000

# Cloud AI Provider API Keys (optional - bring your own)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Ollama Configuration (for local models)
OLLAMA_BASE_URL=http://localhost:11434/api

# Prompt Enrichment Configuration
# Enable/disable prompt enrichment globally
ENRICHMENT_ENABLED=true
# Model to use for prompt enrichment (defaults to fast Groq model)
ENRICHMENT_MODEL=llama-3.1-8b-instant
# Timeout for enrichment in milliseconds (default: 5000ms)
ENRICHMENT_TIMEOUT_MS=5000
# Maximum number of conversation history messages to include in enrichment context
ENRICHMENT_MAX_HISTORY_MESSAGES=5
